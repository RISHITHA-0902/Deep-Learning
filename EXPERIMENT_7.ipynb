      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "def sigmoid(z):\n",
        "    return 1 / (1 + np.exp( - z))\n",
        "plt.plot(np.arange(-5, 5, 0.1), sigmoid(np.arange(-5, 5, 0.1)),color='pink')\n",
        "plt.title('Visualization of the Sigmoid Function')\n",
        "plt.show()"
      ],
